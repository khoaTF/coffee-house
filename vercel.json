{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(login|admin|kitchen|staff|tv)",
      "destination": "/public/$1.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
