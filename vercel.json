{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/public/pages/index.html"
    },
    {
      "source": "/login",
      "destination": "/public/pages/login.html"
    },
    {
      "source": "/admin",
      "destination": "/public/pages/admin.html"
    },
    {
      "source": "/kitchen",
      "destination": "/public/pages/kitchen.html"
    },
    {
      "source": "/staff",
      "destination": "/public/pages/staff.html"
    },
    {
      "source": "/staff-login",
      "destination": "/public/pages/staff-login.html"
    },
    {
      "source": "/tv",
      "destination": "/public/pages/tv.html"
    },
    {
      "source": "/live_index",
      "destination": "/public/pages/live_index.html"
    },
    {
      "source": "/index",
      "destination": "/public/pages/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
