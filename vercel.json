{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin.html"
    },
    {
      "source": "/kitchen",
      "destination": "/pages/kitchen.html"
    },
    {
      "source": "/staff",
      "destination": "/pages/staff.html"
    },
    {
      "source": "/tv",
      "destination": "/pages/tv.html"
    },
    {
      "source": "/delivery",
      "destination": "/pages/delivery.html"
    },
    {
      "source": "/tracking",
      "destination": "/pages/tracking.html"
    },
    {
      "source": "/driver",
      "destination": "/pages/driver.html"
    }
  ]
}
