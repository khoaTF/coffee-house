{
  "version": 2,
  "routes": [
    {
      "src": "/api/payment-webhook",
      "dest": "/api/payment-webhook.js"
    },
    {
      "src": "/api/ai-assistant",
      "dest": "/api/ai-assistant.js"
    },
    {
      "src": "/api/external-order",
      "dest": "/api/external-order.js"
    },
    {
      "src": "/api/generate-invoice",
      "dest": "/api/generate-invoice.js"
    },
    {
      "src": "/api/zalo-notify",
      "dest": "/api/zalo-notify.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api"
    },
    {
      "src": "^/$",
      "dest": "/pages/index.html"
    },
    {
      "src": "^/login$",
      "dest": "/pages/login.html"
    },
    {
      "src": "^/admin$",
      "dest": "/pages/admin.html"
    },
    {
      "src": "^/kitchen$",
      "dest": "/pages/kitchen.html"
    },
    {
      "src": "^/staff$",
      "dest": "/pages/staff.html"
    },
    {
      "src": "^/tv$",
      "dest": "/pages/tv.html"
    },
    {
      "src": "^/delivery$",
      "dest": "/pages/delivery.html"
    },
    {
      "src": "^/tracking$",
      "dest": "/pages/tracking.html"
    },
    {
      "src": "^/driver$",
      "dest": "/pages/driver.html"
    },
    {
      "src": "^/guide$",
      "dest": "/pages/guide.html"
    },
    {
      "src": "^/superadmin$",
      "dest": "/pages/superadmin.html"
    }
  ]
}
